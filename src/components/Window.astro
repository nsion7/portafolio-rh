---
export interface Props {
    termino: string;
    definicion: string;
}
const { termino, definicion } = Astro.props;

// Randomly decide if this window has a plant
const hasPlant = Math.random() > 0.6;
---

<div
    class="window-container flex flex-col items-center group relative cursor-pointer mx-auto w-full max-w-[120px]"
    data-termino={termino}
    data-definicion={definicion}
>
    <!-- The Window Frame -->
    <div
        class="window-frame aspect-square w-full relative overflow-hidden bg-black border-4 sm:border-[6px] border-[#222] shadow-[inset_0_4px_10px_rgba(0,0,0,0.8)] transition-all duration-300"
    >
        <!-- Window Glass / Light inside -->
        <div
            class="window-glass absolute inset-0 bg-[#3b4252] transition-colors duration-500 group-hover:bg-[#4c566a] flex items-center justify-center"
        >
        </div>

        <!-- Shutters -->
        <div
            class="shutter shutter-left absolute inset-y-0 left-0 w-1/2 bg-[#2e3440] border-r-2 border-[#1a1c23] transition-transform duration-700 ease-in-out z-10 shadow-lg"
        >
            <!-- Horizontal slats -->
            <div
                class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0IiBoZWlnaHQ9IjMiPgo8cmVjdCB5PSIyIiB3aWR0aD0iNCIgaGVpZ2h0PSIxIiBmaWxsPSIjMTExIiBmaWxsLW9wYWNpdHk9IjAuNSIvPjwvc3ZnPg==')] opacity-50"
            >
            </div>
        </div>
        <div
            class="shutter shutter-right absolute inset-y-0 right-0 w-1/2 bg-[#2e3440] border-l-2 border-[#1a1c23] transition-transform duration-700 ease-in-out z-10 shadow-lg"
        >
            <div
                class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0IiBoZWlnaHQ9IjMiPgo8cmVjdCB5PSIyIiB3aWR0aD0iNCIgaGVpZ2h0PSIxIiBmaWxsPSIjMTExIiBmaWxsLW9wYWNpdHk9IjAuNSIvPjwvc3ZnPg==')] opacity-50"
            >
            </div>
        </div>

        <!-- Inner content when open -->
        <div
            class="light-icon absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-300 z-0 text-2xl sm:text-3xl drop-shadow-[0_0_8px_rgba(255,255,0,0.8)]"
        >
            💡
        </div>

        <!-- Random Plant -->
        {
            hasPlant && (
                <div
                    class="window-plant absolute bottom-0 right-1 w-4 h-6 sm:w-6 sm:h-8 bg-no-repeat bg-contain z-20 pointer-events-none drop-shadow-md"
                    style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 16 16%22 shape-rendering=%22crispEdges%22><rect x=%226%22 y=%2210%22 width=%224%22 height=%226%22 fill=%22%238B4513%22/><rect x=%227%22 y=%226%22 width=%222%22 height=%224%22 fill=%22%23228B22%22/><rect x=%224%22 y=%224%22 width=%224%22 height=%224%22 fill=%22%2332CD32%22/><rect x=%228%22 y=%222%22 width=%224%22 height=%226%22 fill=%22%2332CD32%22/></svg>');"
                />
            )
        }
    </div>

    <!-- Title Sign -->
    <div
        class="sign mt-2 bg-[#d08770] border-2 border-[#bf616a] px-1 sm:px-2 py-1 text-center shadow-md w-[110%] relative z-20 transition-transform group-hover:scale-105 group-hover:bg-[#ebcb8b] group-hover:border-[#d08770]"
    >
        <span
            class="text-white font-['VT323'] text-[11px] sm:text-[13px] md:text-sm leading-tight block break-words text-shadow-sm group-hover:text-black"
        >
            {termino}
        </span>
    </div>
</div>
